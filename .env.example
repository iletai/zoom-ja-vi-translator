# Speaksy / Zoom JA->VI translator — environment configuration.
#
# Copy this file to ".env" and adjust. ".env" is gitignored (never committed),
# so secrets like the 9router API key stay on your machine only.
#   cp .env.example .env
#
# Real environment variables override these (ZT_ROUTER_MODEL=... python main.py).

# ─── Translator backend ──────────────────────────────────────────────────
# nllb (local, default) | llm (local Qwen) | router (9router gateway)
ZT_TRANSLATOR=router

# ─── 9router gateway (OpenAI-compatible) ─────────────────────────────────
ZT_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
ZT_ROUTER_KEY=sk_9router
# sonnet-4.6 obeys the translate-only prompt; haiku-4.5 slips into assistant
# mode on spoken fragments (部長 → "Vâng, tôi đây ạ"). Use a strong model here.
ZT_ROUTER_MODEL=gh/claude-sonnet-4.6
# Sampling + limits (tuned for live captions)
ZT_ROUTER_TEMPERATURE=0.1
ZT_ROUTER_MAX_TOKENS=180
ZT_ROUTER_TIMEOUT=12
ZT_ROUTER_CONTEXT=3
ZT_ROUTER_MAX_PARALLEL=4
# Override the system prompt (leave unset to use the built-in translate-only prompt)
# ZT_ROUTER_PROMPT=

# ─── Meeting transcript webhook ─────────────────────────────────────────
# Every translated sentence is POSTed here as JSON (fire-and-forget). Use for
# logging the meeting transcript to an external channel (Power Automate, etc.).
# KEEP THIS IN .env ONLY — the URL contains a secret sig= token.
# ZT_WEBHOOK_URL=https://your-flow-url-here
# ZT_WEBHOOK_TIMEOUT=12
# Flush interval in seconds — lines accumulate then send as 1 card (default 30s)
# ZT_WEBHOOK_INTERVAL_S=30

# ─── Meeting transcript webhook (continued) ──────────────────────────────
# HTTP proxy for webhook POSTs (leave unset for direct connection)
# ZT_WEBHOOK_PROXY=http://proxy:3128

# ─── Audio input enrichment (better ASR) ─────────────────────────────────
# Pre-process captured audio before ASR. See src/audio_enrich.py.
ZT_AUDIO_ENRICH=1
ZT_AUDIO_HIGHPASS_HZ=80
ZT_AUDIO_TARGET_RMS=0.05
ZT_AUDIO_MAX_GAIN=8.0
# Noise floor: blocks quieter than this RMS are not gained (avoids pumping noise)
# ZT_AUDIO_NOISE_FLOOR_RMS=0.005
# Per-utterance peak normalization (applied to the whole VAD segment before ASR)
# ZT_AUDIO_UTTERANCE_NORM=1
# ZT_AUDIO_UTTERANCE_PEAK=0.95
# ZT_AUDIO_UTTERANCE_MAX_GAIN=10.0

# ─── Evidence / logging ──────────────────────────────────────────────────
# Write JSONL evidence log to this path (use with run.ps1 -Log or --log flag)
# ZT_EVIDENCE_LOG=test_audio/evidence/live.jsonl
# ZT_LOG_DIR=test_audio/evidence
# ZT_LOG_LEVEL=INFO

# ─── VAD tuning ──────────────────────────────────────────────────────────
# ZT_VAD_AGGRESSIVENESS=3       # 0–3; 3 = most aggressive silence filtering
# ZT_VAD_SILENCE_MS=400         # ms of silence to end a segment
# ZT_VAD_MIN_MS=400             # minimum segment length (ms)
# ZT_VAD_MAX_MS=7000            # force-cut segment at this length (ms)
# ZT_VAD_PREROLL_MS=200         # audio pre-roll before detected speech onset

# ─── Model overrides ─────────────────────────────────────────────────────
# ZT_LLM_MODEL=models/qwen2.5-1.5b-instruct/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf
# NLLB_CT2_DIR=models/nllb-200-distilled-600M-ct2-int8
# ZT_HOTWORDS_FILE=hotwords_it.txt
# ZT_HOTWORDS_SCORE=80
