# Speaksy / Zoom JA->VI translator — environment configuration.
#
# Copy this file to ".env" and adjust. ".env" is gitignored (never committed),
# so secrets like the 9router API key stay on your machine only.
#   cp .env.example .env
#
# Real environment variables override these (ZT_ROUTER_MODEL=... python main.py).

# ─── Translator backend ──────────────────────────────────────────────────
# nllb (local, default) | llm (local Qwen) | router (9router gateway)
ZT_TRANSLATOR=router

# ─── 9router gateway (OpenAI-compatible) ─────────────────────────────────
ZT_ROUTER_BASE_URL=http://127.0.0.1:20128/v1
ZT_ROUTER_KEY=sk_9router
# sonnet-4.6 obeys the translate-only prompt; haiku-4.5 slips into assistant
# mode on spoken fragments (部長 → "Vâng, tôi đây ạ"). Use a strong model here.
ZT_ROUTER_MODEL=gh/claude-sonnet-4.6
# Sampling + limits (tuned for live captions)
ZT_ROUTER_TEMPERATURE=0.1
ZT_ROUTER_MAX_TOKENS=180
ZT_ROUTER_TIMEOUT=6
ZT_ROUTER_CONTEXT=3
ZT_ROUTER_MAX_PARALLEL=4
# Override the system prompt (leave unset to use the built-in translate-only prompt)
# ZT_ROUTER_PROMPT=

# ─── Audio input enrichment (better ASR) ─────────────────────────────────
# Pre-process captured audio before ASR. See src/audio_enrich.py.
ZT_AUDIO_ENRICH=1
ZT_AUDIO_HIGHPASS_HZ=80
ZT_AUDIO_TARGET_RMS=0.05
ZT_AUDIO_MAX_GAIN=8.0
